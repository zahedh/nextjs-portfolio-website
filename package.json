    "next": "^15.5.4",
    "react": "^19.2.0",
    "react-activity-calendar": "^3.0.5",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "swiper": "^12.1.0",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
